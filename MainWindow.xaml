<Window x:Class="CalculatorWithHistory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CalculatorWithHistory"
        mc:Ignorable="d"
        Title="Калькулятор" Height="350" Width="250"
        ResizeMode="CanMinimize">
    <DockPanel>
        <!--Меню-->
        <Menu Background="White" DockPanel.Dock="Top">
            <MenuItem Header="_ 📝" FontSize="10" Click="MenuItem_Click"></MenuItem>
            <MenuItem Header="_ ✏️" FontSize="10" Click="MenuItemEditHistoryClick"></MenuItem>
            <MenuItem Header="_ 👩‍💻" FontSize="10" Click="MenuItemInfoClick"></MenuItem>
        </Menu>
        <!--Калькулятор-->
        <Border Padding="13">
            <Border.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="#FFECF3FC"/>
                    <GradientStop Color="#FFD9E4F1" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <!--Окно ввода в калькуляторе-->
                <TextBox x:Name="ResultTextBox" DockPanel.Dock="Top" Height="50" IsReadOnly="True" Text="0" 
                         VerticalContentAlignment="Bottom" HorizontalContentAlignment="Right" FontSize="20" Padding="0 0 3 5" FontFamily="Segoe UI Black" TextChanged="TextBox_TextChanged_1">
                    <TextBox.Background>
                        <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                            <GradientStop Color="#FFE6EFFF"/>
                            <GradientStop Color="White" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBox.Background>
                </TextBox>
                <!--Кнопки-->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="5"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="5"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="5"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                        <ColumnDefinition Width="5"></ColumnDefinition>
                        <ColumnDefinition></ColumnDefinition>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition></RowDefinition>
                        <RowDefinition Height="5"></RowDefinition>
                        <RowDefinition></RowDefinition>
                    </Grid.RowDefinitions>
                    <!--1 ряд-->
                    <Button Content="MC" Grid.Column="0" Grid.Row="1" Click="ButtonMCClick"></Button>
                    <Button Content="MR" Grid.Column="2" Grid.Row="1" Click="ButtonMRClick"></Button>
                    <Button Content="MS" Grid.Column="4" Grid.Row="1" Click="ButtonMSClick"></Button>
                    <Button Content="M+" Grid.Column="6" Grid.Row="1" Click="ButtonMPlusClick"></Button>
                    <Button Content="M-" Grid.Column="8" Grid.Row="1" Click="ButtonMMinusClick"></Button>
                    <!--2 ряд-->
                    <Button Content="←" Grid.Column="0" Grid.Row="3" Click="ButtonDelClick"></Button>
                    <Button Content="CE" Grid.Column="2" Grid.Row="3" Click="ButtonCEClick"></Button>
                    <Button Content="C" Grid.Column="4" Grid.Row="3" Click="ButtonCClick"></Button>
                    <Button Content="±" Grid.Column="6" Grid.Row="3" Click="ButtonReverseClick"></Button>
                    <Button Content="√" Grid.Column="8" Grid.Row="3" Click="ButtonRootClick"></Button>
                    <!--3 ряд-->
                    <Button Content="7" Grid.Column="0" Grid.Row="5" Click="ButtonNumberClick"></Button>
                    <Button Content="8" Grid.Column="2" Grid.Row="5" Click="ButtonNumberClick"></Button>
                    <Button Content="9" Grid.Column="4" Grid.Row="5" Click="ButtonNumberClick"></Button>
                    <Button Content="/" Grid.Column="6" Grid.Row="5" Click="ButtonDivideClick"></Button>
                    <Button Content="%" Grid.Column="8" Grid.Row="5" Click="ButtonPercentClick"></Button>
                    <!--4 ряд-->
                    <Button Content="4" Grid.Column="0" Grid.Row="7" Click="ButtonNumberClick"></Button>
                    <Button Content="5" Grid.Column="2" Grid.Row="7" Click="ButtonNumberClick"></Button>
                    <Button Content="6" Grid.Column="4" Grid.Row="7" Click="ButtonNumberClick"></Button>
                    <Button Content="*" Grid.Column="6" Grid.Row="7" Click="ButtonMultiplyClick"></Button>
                    <Button Content="1/x" Grid.Column="8" Grid.Row="7" Click="ButtonRevNumClick"></Button>
                    <!--5 ряд-->
                    <Button Content="1" Grid.Column="0" Grid.Row="9" Click="ButtonNumberClick"></Button>
                    <Button Content="2" Grid.Column="2" Grid.Row="9" Click="ButtonNumberClick"></Button>
                    <Button Content="3" Grid.Column="4" Grid.Row="9" Click="ButtonNumberClick"></Button>
                    <Button Content="-" Grid.Column="6" Grid.Row="9" Click="ButtonMinusClick"></Button>
                    <Button Content="=" Grid.Column="8" Grid.Row="9" Grid.RowSpan="3" Click="ButtonEqualClick"></Button>
                    <!--6 ряд-->
                    <Button Content="0" Grid.Column="0" Grid.Row="11" Grid.ColumnSpan="3" Click="ButtonNumberClick"></Button>
                    <Button Content="," Grid.Column="4" Grid.Row="11" Click="ButtonCommaClick"></Button>
                    <Button Content="+" Grid.Column="6" Grid.Row="11" Click="ButtonSumClick"></Button>
                </Grid>
            </DockPanel>
        </Border>
    </DockPanel>
</Window>
